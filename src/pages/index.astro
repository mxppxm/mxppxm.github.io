---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BookmarkWall from "../components/BookmarkWall.astro";
import WindowSwap from "../components/WindowSwap.astro";

const allArticles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Always include the latest from each series, plus standalone articles
// Sort novel by chapter number desc to get real latest
const novelChapters = allArticles
  .filter((a) => a.id.includes("novel-chapter"))
  .sort((a, b) => {
    const numA = parseInt(a.id.match(/chapter-(\d+)/)?.[1] || "0");
    const numB = parseInt(b.id.match(/chapter-(\d+)/)?.[1] || "0");
    return numB - numA;
  });
const latestNovel = novelChapters[0];
const latestGold = allArticles.find((a) => a.id.includes("gold-daily"));
const seriesIds = new Set([latestNovel?.id, latestGold?.id].filter(Boolean));

const latestArticles = [
  // Always-pinned latest from each series + all standalone articles
  ...allArticles.filter((a) => {
    if (seriesIds.has(a.id)) return true;
    if (a.id.includes("novel-chapter") || a.id.includes("gold-daily")) return false;
    return true;
  }),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 8);
---

<BaseLayout
