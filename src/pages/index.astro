    </div>
  </WindowSwap>

  <!-- ====== ABOUT ====== -->
  <section id="about" class="section section-dark">
    <div class="section-inner">
      <h2 class="section-title">关于我</h2>
      <div class="about-grid">
        <div class="about-text">
          <p>
            我是 <strong>九日</strong>，一名前端工程师，也是一个热爱折腾的创意工作者。
          </p>
          <p>
            从 P2P 聊天到烟花特效，从提示词优化到习惯追踪——每个项目都是我和代码的一次碰撞实验。相信技术应该是好玩的、有温度的，最好的代码往往诞生于好奇心和一点点的强迫症。
          </p>
        </div>
        <div class="about-stats">
          <div class="stat">
            <div class="stat-num">8+</div>
            <div class="stat-label">开源项目</div>
          </div>
          <div class="stat">
            <div class="stat-num">{allArticles.length}</div>
            <div class="stat-label">篇文章</div>
          </div>
          <div class="stat">
            <div class="stat-num">1</div>
            <div class="stat-label">已部署项目</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== LIVE PROJECTS ====== -->
  <section id="live-projects" class="section section-accent">
    <div class="section-inner">
      <h2 class="section-title">在线项目</h2>
      <div class="live-projects-grid">

        <a href="https://skin-doctor.netlify.app/" target="_blank" rel="noopener" class="live-project-card">
          <div class="live-project-icon">
            <img src="/logo.png" alt="皮肤检测器" width="36" height="36" style="border-radius:8px;" />
          </div>
          <div class="live-project-body">
            <h3>皮肤检测器</h3>
            <p>AI 驱动的皮肤分析工具 — 拍照上传，获取多维度的肤质评分与个性化护肤建议。React + TypeScript + Tailwind，多模型支持。</p>
            <div class="live-project-tags">
              <span>React</span><span>TypeScript</span><span>AI</span><span>Netlify</span>
            </div>
          </div>
          <span class="live-project-arrow">→</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ====== PROJECTS ====== -->
  <section id="projects" class="section">
    <div class="section-inner">
      <h2 class="section-title">项目精选</h2>
      <div id="projects-grid" class="projects-grid">
        <div class="projects-loading">加载中...</div>
      </div>
      <div class="section-more">
        <a href="https://github.com/mxppxm" target="_blank" rel="noopener" class="btn btn-outline">
          查看全部项目
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ====== BOOKMARK WALL ====== -->
  <BookmarkWall />

  <!-- ====== BLOG ====== -->
  <section id="blog" class="section section-dark">
    <div class="section-inner">
      <div class="section-label">Writing</div>
      <h2 class="section-title">最近文章</h2>
      <ul class="post-list">
        {latestArticles.map((article) => {
          const slug = article.id.replace(/\.md$/, "");
          const url = `/articles/${slug}/`;
          const isNew = (Date.now() - article.data.date.getTime()) < 3 * 24 * 60 * 60 * 1000;
          return (
            <li class="post-card" onclick={`location.href='${url}'`}>
              <div class="post-card-date">
                {article.data.date.toLocaleDateString("zh-CN", { month: "short", day: "numeric" })}
              </div>
              <div class="post-card-body">
                {isNew && <span class="post-card-badge">NEW</span>}
                <h2><a href={url}>{article.data.title}</a></h2>
                <p>{article.data.description}</p>
                <div class="post-tags">
                  {article.data.tags.map((tag) => <span class="post-tag">{tag}</span>)}
                </div>
              </div>
            </li>
          );
        })}
      </ul>
      <p class="writing-more">更多文章正在路上……</p>
    </div>
  </section>

  <!-- ====== CONTACT ====== -->
  <section id="contact" class="section">
    <div class="section-inner">
      <h2 class="section-title-sm">找到我</h2>
      <div class="contact-row">
        <p style="font-size:15px;color:var(--text-secondary);margin-right:8px;">
          有想法就聊聊，别客气——
        </p>
        <a href="https://github.com/mxppxm" target="_blank" rel="noopener" class="contact-link">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span>mxppxm</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline src="/js/github-projects.js"></script>
