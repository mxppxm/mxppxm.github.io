---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allArticles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Latest articles for blog section（去重：小说/黄金日报只显示最新一篇）
const seenSeries = new Set<string>();
const latestArticles = allArticles.filter((a) => {
  const slug = a.id;
  // 小说系列只保留最新一章
  if (slug.includes("novel-chapter")) {
    if (seenSeries.has("novel")) return false;
    seenSeries.add("novel");
    return true;
  }
  // 黄金日报只保留最新一篇
  if (slug.includes("gold-daily")) {
    if (seenSeries.has("gold-daily")) return false;
    seenSeries.add("gold-daily");
    return true;
  }
  return true;
}).slice(0, 7);
---

