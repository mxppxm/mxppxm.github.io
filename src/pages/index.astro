---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allArticles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const seenSeries = new Set<string>();
const latestArticles = allArticles.filter((a) => {
  const slug = a.id;
  if (slug.includes("novel-chapter")) {
    if (seenSeries.has("novel")) return false;
    seenSeries.add("novel");
    return true;
  }
  if (slug.includes("gold-daily")) {
    if (seenSeries.has("gold-daily")) return false;
    seenSeries.add("gold-daily");
    return true;
  }
  return true;
}).slice(0, 7);
---

<BaseLayout
