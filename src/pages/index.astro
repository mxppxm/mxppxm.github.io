  </section>

  <!-- ====== Projects ====== -->
  <section id="projects" class="section">
    <div class="container">
      <h2 class="section-title">项目精选</h2>
      <p class="section-subtitle">一些我觉得好玩的 side project</p>
      <div id="projects-grid" class="projects-grid">
        <div class="s12 center-align padding">加载中...</div>
      </div>
      <div class="section-cta">
        <a href="https://github.com/mxppxm" target="_blank" rel="noopener" class="btn btn-secondary">查看全部项目 →</a>
      </div>
    </div>
  </section>

  <!-- ====== Blog ====== -->
  <section id="blog" class="section section-alt">
    <div class="container">
      <h2 class="section-title">最近文章</h2>
      <p class="section-subtitle">偶尔写点东西，记录思考</p>
      <ul class="post-list">
        {latestArticles.map((article) => {
          const slug = article.id.replace(/\.md$/, "");
          const url = `/articles/${slug}/`;
          const isNew = (Date.now() - article.data.date.getTime()) < 3 * 24 * 60 * 60 * 1000;
          return (
            <li class="post-card" data-date={article.data.date.toISOString().split("T")[0]} onclick={`location.href='${url}'`}>
              {isNew && <span class="post-card-badge">最新</span>}
              <h2><a href={url}>{article.data.title}</a></h2>
              <div class="post-meta">
                {article.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
              </div>
              <p class="post-excerpt">{article.data.description}</p>
              <div class="post-tags">
                {article.data.tags.map((tag) => <span class="post-tag">{tag}</span>)}
              </div>
            </li>
          );
        })}
      </ul>
      <p class="writing-coming section-cta">更多文章正在路上……</p>
    </div>
  </section>

  <!-- ====== Contact ====== -->
  <section id="contact" class="section">
