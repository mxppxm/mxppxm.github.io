---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((a) => {
    const tags = a.data.tags;
    const isNovel = tags.some((t: string) => t.includes("小说"));
    const isGold = tags.some((t: string) => t.includes("黄金"));
    return !isNovel && !isGold;
  })
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="📝 杂文"
  description="旅行、生活、技术随想 — 九日"
>
  <div class="listing-page">
    <div class="listing-hero">
      <div class="listing-hero-inner">
        <h1>杂文</h1>
        <p>旅行手记、生活随想、技术之外的一切。</p>
        <div class="listing-stats">
          <div class="listing-stat">
            <span class="listing-stat-num">{articles.length}</span>
            <span class="listing-stat-label">篇</span>
          </div>
        </div>
      </div>
    </div>

    <div class="listing-body">
      {articles.length > 0 ? (
        <div class="listing-grid">
          {articles.map((article) => {
            const slug = article.id.replace(/\.md$/, "");
            const url = `/articles/${slug}/`;
            return (
              <article class="listing-card" onclick={`location.href='${url}'`}>
                <div class="listing-card-date">
                  {article.data.date.toLocaleDateString("zh-CN", { month: "short", day: "numeric" })}
                </div>
                <div class="listing-card-body">
                  <h3><a href={url}>{article.data.title}</a></h3>
                  <p>{article.data.description}</p>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="listing-empty">
          <p>📝 还没有杂文，在路上……</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
