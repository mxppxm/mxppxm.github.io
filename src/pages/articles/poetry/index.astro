---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((a) => a.data.tags.some((t) => t.includes("毛泽东诗词")))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const periodCounts = {
  "早期": articles.filter(a => a.data.period === "早期").length,
  "革命时期": articles.filter(a => a.data.period === "革命时期").length,
  "建国后": articles.filter(a => a.data.period === "建国后").length,
};
---

<BaseLayout
  title="📜 毛泽东诗词"
  description="毛泽东诗词全集 — 九日"
>
  <div class="listing-page">
    <div class="listing-hero">
      <div class="listing-hero-inner">
        <span class="listing-hero-icon">📜</span>
        <h1>毛泽东诗词</h1>
        <p>从青年到晚年，从井冈山到北京，毛泽东诗词记录了一个世纪的激荡风云。按创作时间排序，完整呈现诗词全貌。</p>
        <div class="listing-stats">
          <div class="listing-stat">
            <span class="listing-stat-num">{articles.length}</span>
            <span class="listing-stat-label">首</span>
          </div>
          {Object.entries(periodCounts).map(([k, v]) => (
            <div class="listing-stat">
              <span class="listing-stat-num">{v}</span>
              <span class="listing-stat-label">{k}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="listing-body">
      <div class="listing-grid">
        {articles.map((article) => {
          const slug = article.id.replace(/\.md$/, "");
          const url = `/articles/${slug}/`;
          const cipaiLabel = article.data.cipai || "";
          const periodLabel = article.data.period || "";
          const dateStr = article.data.date.toLocaleDateString("zh-CN", { year: "numeric" });
          return (
            <article class="listing-card" onclick={`location.href='${url}'`}>
              <div class="listing-card-date">
                {cipaiLabel || dateStr}
              </div>
              <div class="listing-card-body">
                <h3><a href={url}>{article.data.title}</a></h3>
                <p>{article.data.description}</p>
                <div class="listing-card-tags">
                  {periodLabel && <span class="listing-card-tag listing-card-tag-period">{periodLabel}</span>}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .listing-hero-icon { display: block; font-size: 36px; margin-bottom: 12px; }

  .listing-card-tags {
    display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap;
  }
  .listing-card-tag {
    font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 12px;
    letter-spacing: 0.03em;
  }
  .listing-card-tag-period {
    color: var(--text-muted);
    background: #F0EDE8;
  }
</style>
