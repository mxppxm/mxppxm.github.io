---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((a) => a.data.tags.some((t) => t.includes("小说")))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<BaseLayout
  title="📖 小说 — 《槐树下》"
  description="AI 共创现实主义小说《槐树下》 — 九日"
>
  <section class="padding">
    <h1 class="center-align">📖 《槐树下》</h1>
    <p class="center-align">AI 共创 · 现实主义小说</p>

    <div class="max" style="max-width: 800px; margin: 0 auto;">
      {articles.map((article) => {
        const slug = article.id.replace(/\.md$/, "");
        const url = `/articles/${slug}/`;
        return (
          <article class="round fill margin bottom" style="cursor: pointer;" onclick={`location.href='${url}'`}>
            <div class="padding">
              <h5><a href={url}>{article.data.title}</a></h5>
              <div class="small-text">
                {article.data.date.toLocaleDateString("zh-CN", {
                  year: "numeric", month: "long", day: "numeric",
                })}
              </div>
              <p class="small-text">{article.data.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
