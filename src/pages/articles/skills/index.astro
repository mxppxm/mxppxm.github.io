---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((a) => a.data.tags.some((t) => t.includes("Skill")))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="🧰 Skill 工具箱"
  description="Clacky AI Skill 开发 — 九日"
>
  <div class="listing-page">
    <div class="listing-inner">
      <div class="listing-header">
        <h1>🧰 Skill 工具箱</h1>
        <p>Clacky AI Skill 开发笔记</p>
      </div>
      <div class="listing-grid">
        {articles.map((article) => {
          const slug = article.id.replace(/\.md$/, "");
          const url = `/articles/${slug}/`;
          return (
            <article class="listing-card" onclick={`location.href='${url}'`}>
              <div class="listing-card-date">
                {article.data.date.toLocaleDateString("zh-CN", { month: "short", day: "numeric" })}
              </div>
              <div class="listing-card-body">
                <h3><a href={url}>{article.data.title}</a></h3>
                <p>{article.data.description}</p>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</BaseLayout>
