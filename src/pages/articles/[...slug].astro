---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, "") },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const isNovel = article.data.tags.some((t: string) => t.includes("小说"));
const isGold = article.data.tags.some((t: string) => t.includes("黄金"));
const isSkill = article.data.tags.some((t: string) => t.includes("Skill"));
const isPoetry = article.data.tags.some((t: string) => t.includes("毛泽东诗词"));

let backUrl = "/#blog";
let backLabel = "← 返回首页";
if (isNovel) { backUrl = "/articles/novel/"; backLabel = "← 槐树下"; }
if (isGold) { backUrl = "/articles/gold/"; backLabel = "← 黄金专区"; }
if (isSkill) { backUrl = "/articles/skills/"; backLabel = "← Skill 工具箱"; }
if (isPoetry) { backUrl = "/articles/poetry/"; backLabel = "← 诗词专区"; }

// Navigation helpers
let prevNav: { title: string; url: string } | null = null;
let nextNav: { title: string; url: string } | null = null;

// Novel prev/next chapter
if (isNovel) {
  const allChapters = (await getCollection("articles"))
    .filter((a) => a.data.tags.some((t: string) => t.includes("小说")))
    .sort((a, b) => {
      const numA = parseInt(a.id.match(/chapter-(\d+)/)?.[1] || "0");
      const numB = parseInt(b.id.match(/chapter-(\d+)/)?.[1] || "0");
      return numA - numB;
    });

  const currentIdx = allChapters.findIndex((a) => a.id === article.id);
  if (currentIdx > 0) {
    const prev = allChapters[currentIdx - 1];
    prevNav = { title: prev.data.title, url: `/articles/${prev.id.replace(/\.md$/, "")}/` };
  }
  if (currentIdx < allChapters.length - 1) {
    const next = allChapters[currentIdx + 1];
    nextNav = { title: next.data.title, url: `/articles/${next.id.replace(/\.md$/, "")}/` };
  }
}

// Poetry prev/next poem (sorted by date)
if (isPoetry) {
  const allPoems = (await getCollection("articles"))
    .filter((a) => a.data.tags.some((t: string) => t.includes("毛泽东诗词")))
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

  const currentIdx = allPoems.findIndex((a) => a.id === article.id);
  if (currentIdx > 0) {
    const prev = allPoems[currentIdx - 1];
    prevNav = { title: prev.data.title, url: `/articles/${prev.id.replace(/\.md$/, "")}/` };
  }
  if (currentIdx < allPoems.length - 1) {
    const next = allPoems[currentIdx + 1];
    nextNav = { title: next.data.title, url: `/articles/${next.id.replace(/\.md$/, "")}/` };
  }
}
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
>
  <div class="article-page">
    <div class="article-layout">
      <div class="article-main">
        <a href={backUrl} class="article-back">{backLabel}</a>
        {isPoetry && article.data.image && (
          <div class="article-hero-image">
            <img src={article.data.image} alt={article.data.title} loading="eager" />
          </div>
        )}
        <header class="article-header">
          <h1>{article.data.title}</h1>
          {article.data.audio === true ? (
            <div class="audio-player" data-audio-id={article.id.replace(/\.md$/, "")}>
              <button class="audio-btn" aria-label="播放">
                <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
              </button>
              <div class="audio-progress-track">
                <div class="audio-progress-fill"></div>
              </div>
              <span class="audio-time">00:00</span>
              <span class="audio-dur"> / 00:00</span>
              <audio preload="metadata">
                <source src={"/audio/" + article.id.replace(/\.md$/, "") + ".mp3"} type="audio/mpeg" />
              </audio>
            </div>
          ) : null}
          <div class="article-meta">
            {article.data.date.toLocaleDateString("zh-CN", {
              year: "numeric", month: "long", day: "numeric",
            })}
          </div>
          {article.data.tags.length > 0 && (
            <div class="article-tags">
              {article.data.tags.map((tag: string) => (
                <span class="article-tag">{tag}</span>
              ))}
            </div>
          )}
        </header>
        <div
          class={`article-content${isPoetry ? " poem-content" : ""}`}
          data-poem-type={isPoetry ? article.data.poem_type || "" : undefined}
          data-cipai={isPoetry && article.data.cipai ? article.data.cipai : undefined}
        >
          <Content />
        </div>

        {/* Prev/Next chapter navigation */}
        {(isNovel || isPoetry) && (prevNav || nextNav) && (
          <nav class="chapter-nav">
            {prevNav ? (
              <a href={prevNav.url} class="chapter-nav-link chapter-nav-prev">
                <span class="chapter-nav-label">← {isNovel ? "上一章" : "上一首"}</span>
                <span class="chapter-nav-title">{prevNav.title}</span>
              </a>
            ) : <div></div>}
            {nextNav ? (
              <a href={nextNav.url} class="chapter-nav-link chapter-nav-next">
                <span class="chapter-nav-label">{isNovel ? "下一章" : "下一首"} →</span>
                <span class="chapter-nav-title">{nextNav.title}</span>
              </a>
            ) : <div></div>}
          </nav>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  function initAudioPlayers() {
    document.querySelectorAll('.audio-player').forEach(player => {
      const btn = player.querySelector('.audio-btn');
      const audio = player.querySelector('audio');
      const fill = player.querySelector('.audio-progress-fill');
      const track = player.querySelector('.audio-progress-track');
      const timeEl = player.querySelector('.audio-time');
      const durEl = player.querySelector('.audio-dur');
      const playIcon = btn.querySelector('.icon-play');
      const pauseIcon = btn.querySelector('.icon-pause');

      if (!audio) return;

      function fmt(t) {
        const m = Math.floor(t / 60);
        const s = Math.floor(t % 60);
        return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
      }

      audio.addEventListener('loadedmetadata', () => {
        durEl.textContent = ' / ' + fmt(audio.duration);
      });

      audio.addEventListener('timeupdate', () => {
        const pct = (audio.currentTime / audio.duration) * 100;
        fill.style.width = pct + '%';
        timeEl.textContent = fmt(audio.currentTime);
      });

      audio.addEventListener('play', () => {
        player.classList.add('playing');
        playIcon.style.display = 'none';
        pauseIcon.style.display = '';
      });

      audio.addEventListener('pause', () => {
        player.classList.remove('playing');
        playIcon.style.display = '';
        pauseIcon.style.display = 'none';
      });

      audio.addEventListener('ended', () => {
        player.classList.remove('playing');
        playIcon.style.display = '';
        pauseIcon.style.display = 'none';
        fill.style.width = '0%';
        timeEl.textContent = '00:00';
      });

      btn.addEventListener('click', () => {
        if (audio.paused) {
          audio.play();
        } else {
          audio.pause();
        }
      });

      track.addEventListener('click', (e) => {
        const rect = track.getBoundingClientRect();
        const pct = (e.clientX - rect.left) / rect.width;
        audio.currentTime = pct * audio.duration;
      });
    });
  }

  initAudioPlayers();
  document.addEventListener('astro:page-load', initAudioPlayers);

  // ── Poetry DOM enhancement ──
  function enhancePoetry() {
    const poem = document.querySelector('.poem-content');
    if (!poem) return;

    const poemType = poem.dataset.poemType;
    const hr = poem.querySelector('hr');
    if (!hr) return;

    // Collect all <p> before <hr> — skip the first one (date/subtitle line)
    const bodyParagraphs = [];
    let el = poem.firstElementChild;
    let isFirstP = true;
    while (el && el !== hr) {
      if (el.tagName === 'P') {
        if (isFirstP) {
          isFirstP = false;
          // Keep the date line as-is, add class for styling
          el.classList.add('poem-date');
        } else {
          bodyParagraphs.push(el);
        }
      }
      el = el.nextElementSibling;
    }

    // Create wrapper for poem body
    const verseWrap = document.createElement('div');
    verseWrap.className = 'verse-body';
    if (poemType) verseWrap.classList.add('verse-' + poemType);

    if (poemType === 'shi') {
      // ── 律诗/绝句：一句一行 ──
      bodyParagraphs.forEach(p => {
        const lines = p.innerHTML.split(/<br\s*\/?>/i);
        const cleanedLines = lines.map(l => l.trim()).filter(Boolean);
        cleanedLines.forEach(line => {
          const div = document.createElement('div');
          div.className = 'line';
          div.innerHTML = line;
          verseWrap.appendChild(div);
        });
      });
    } else if (poemType === 'ci') {
      // ── 词牌：每个 <p> 就是一阕 ──
      bodyParagraphs.forEach((p, idx) => {
        const stanza = document.createElement('div');
        stanza.className = 'stanza';
        stanza.innerHTML = p.innerHTML.replace(/<br\s*\/?>/gi, '\n');
        // Split by newlines for individual line styling
        const lines = stanza.innerHTML.split('\n').map(l => l.trim()).filter(Boolean);
        stanza.innerHTML = lines.map(l => `<span class="line">${l}</span>`).join('');
        if (idx === 0) stanza.classList.add('stanza-upper');
        if (idx === 1) stanza.classList.add('stanza-lower');
        verseWrap.appendChild(stanza);
      });

      // If only one stanza (no blank line in markdown), split at 3-char line (三字句)
      // e.g., "风樯动，龟蛇静，起宏图。" — short lines often mark 下阕 start
      if (bodyParagraphs.length === 1) {
        const lines = bodyParagraphs[0].innerHTML.split(/<br\s*\/?>/i).map(l => l.trim()).filter(Boolean);
        // Find split point: first line ≤ 7 chars (like "风樯动，龟蛇静，起宏图。")
        let splitIdx = -1;
        for (let i = 0; i < lines.length; i++) {
          const text = lines[i].replace(/<[^>]*>/g, '');
          if (text.length <= 9 && i > 0) { splitIdx = i; break; }
        }
        if (splitIdx > 0) {
          verseWrap.innerHTML = '';
          const upper = document.createElement('div');
          upper.className = 'stanza stanza-upper';
          upper.innerHTML = lines.slice(0, splitIdx).map(l => `<span class="line">${l}</span>`).join('');
          verseWrap.appendChild(upper);

          const divider = document.createElement('div');
          divider.className = 'stanza-divider';
          verseWrap.appendChild(divider);

          const lower = document.createElement('div');
          lower.className = 'stanza stanza-lower';
          lower.innerHTML = lines.slice(splitIdx).map(l => `<span class="line">${l}</span>`).join('');
          verseWrap.appendChild(lower);
        }
      }
    } else {
      // ── 古体诗 / 默认：保留原格式 ──
      bodyParagraphs.forEach(p => {
        const div = document.createElement('div');
        div.className = 'verse-line';
        div.innerHTML = p.innerHTML;
        verseWrap.appendChild(div);
      });
    }

    // Insert verse body before hr, remove original paragraphs
    bodyParagraphs.forEach(p => p.remove());
    hr.parentNode.insertBefore(verseWrap, hr);
  }

  enhancePoetry();
  document.addEventListener('astro:page-load', enhancePoetry);
</script>

<style>
  /* ── Custom Audio Player ── */
  .audio-player {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0 0;
    padding: 10px 16px;
    max-width: 420px;
    background: var(--bg-secondary, #f5f5f5);
    border-radius: 40px;
    border: 1px solid var(--border);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .audio-player.playing {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .audio-btn {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 50%;
    border: none;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.15s, background 0.2s;
  }
  .audio-btn:hover { transform: scale(1.08); }
  .audio-btn:active { transform: scale(0.95); }

  .audio-progress-track {
    flex: 1;
    height: 5px;
    background: var(--border);
    border-radius: 3px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .audio-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.1s linear;
  }

  .audio-time {
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
    min-width: 38px;
    text-align: right;
  }
  .audio-dur {
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
  }

  .article-back {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 13.5px; font-weight: 500;
    color: var(--text-muted); text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .article-back:hover { color: var(--accent); }

  .article-hero-image {
    margin: 0 0 32px;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .article-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .chapter-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .chapter-nav-link {
    display: flex; flex-direction: column; gap: 4px;
    padding: 16px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.25s var(--ease);
  }
  .chapter-nav-link:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-sm);
  }
  .chapter-nav-next { text-align: right; }
  .chapter-nav-label {
    font-size: 12px; font-weight: 600; color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .chapter-nav-title {
    font-size: 14px; font-weight: 500; color: var(--text-secondary);
    line-height: 1.4;
  }
</style>
