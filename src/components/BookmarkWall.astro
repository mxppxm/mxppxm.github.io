---
import bookmarks from "../data/bookmarks.json";

// Shuffle cards slightly for organic feel — deterministic by index
const getCardStyle = (i: number) => {
  const rotations = [-1.2, 0.8, -0.5, 1.0, -0.7, 0.3, -0.9, 0.6];
  const rot = rotations[i % rotations.length];
  return `--rot: ${rot}deg;`;
};
---

<section id="inspirations" class="section">
  <div class="section-inner">
    <div class="section-label">Curated</div>
    <h2 class="section-title">灵感收藏架</h2>

    <div class="bookmark-wall">
      {bookmarks.map((bm, i) => (
        <a
          href={bm.url}
          target="_blank"
          rel="noopener"
          class="bookmark-card"
          style={getCardStyle(i)}
        >
          <div class="bookmark-card-inner">
            <div class="bookmark-icon">{bm.icon}</div>
            <h3 class="bookmark-name">{bm.name}</h3>
            <p class="bookmark-desc">{bm.desc}</p>
            <div class="bookmark-footer">
              <span class="bookmark-tag">{bm.tag}</span>
              <span class="bookmark-arrow">↗</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
/* ═══════════════════════════════════════════════════════════
   BOOKMARK WALL — masonry scrapbook aesthetic
   ═══════════════════════════════════════════════════════════ */
.bookmark-wall {
  column-count: 3;
  column-gap: 20px;
  max-width: 1100px;
}

.bookmark-card {
  display: block;
  break-inside: avoid;
  margin-bottom: 20px;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  --rot: 0deg;
  transform: rotate(var(--rot));
  transition:
    transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.bookmark-card:hover {
  transform: rotate(0deg) translateY(-6px);
  z-index: 2;
}

.bookmark-card-inner {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 28px 26px;
  border: 1.5px solid var(--border-light);
  box-shadow: var(--shadow-sm);
  position: relative;
  transition:
    border-color 0.3s var(--ease-out),
    box-shadow 0.4s var(--ease-out);
  overflow: hidden;
}

/* Accent top bar — subtle */
.bookmark-card-inner::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), rgba(7,193,96,0.25));
  border-radius: 3px 3px 0 0;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.45s var(--ease-out);
}

.bookmark-card:hover .bookmark-card-inner {
  border-color: var(--accent);
  box-shadow: var(--shadow-lg);
}

.bookmark-card:hover .bookmark-card-inner::before {
  transform: scaleX(1);
}

.bookmark-icon {
  font-size: 40px;
  line-height: 1;
  margin-bottom: 16px;
  display: block;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bookmark-card:hover .bookmark-icon {
  transform: scale(1.15);
}

.bookmark-name {
  font-size: 18px;
  font-weight: 680;
  margin-bottom: 8px;
  color: var(--text);
  letter-spacing: -0.3px;
  line-height: 1.3;
}

.bookmark-desc {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 16px;
}

.bookmark-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bookmark-tag {
  font-size: 11.5px;
  font-weight: 600;
  padding: 4px 12px;
  background: var(--accent-light);
  color: var(--accent-dark);
  border-radius: 10px;
  letter-spacing: 0.2px;
}

.bookmark-arrow {
  font-size: 15px;
  color: var(--text-muted);
  opacity: 0;
  transform: translateX(-6px);
  transition:
    opacity 0.3s var(--ease-out),
    transform 0.3s var(--ease-out),
    color 0.3s var(--ease-out);
}

.bookmark-card:hover .bookmark-arrow {
  opacity: 1;
  transform: translateX(0);
  color: var(--accent);
}

/* Empty placeholder */
.bookmark-card-empty {
  pointer-events: none;
  opacity: 0.4;
  transform: rotate(0.3deg);
}

.bookmark-card-empty .bookmark-card-inner {
  border-style: dashed;
  text-align: center;
  padding: 32px 26px;
}

.bookmark-card-empty .bookmark-card-inner::before {
  display: none;
}

.bookmark-icon-plus {
  font-size: 32px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.bookmark-desc-muted {
  color: var(--text-muted);
  font-size: 13.5px;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .bookmark-wall {
    column-count: 2;
  }
}

@media (max-width: 560px) {
  .bookmark-wall {
    column-count: 1;
    max-width: 400px;
    margin: 0 auto;
  }
}
</style>
